{
  "name": "bq-mcp-server",
  "version": "1.0.0",
  "description": "MCP server bridging KiloCode to BetterQuesting via an in-game mod",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "node node_modules/esbuild/bin/esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:esbuild",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "kilocode": {
    "mcpServer": {
      "command": "node",
      "args": [
        "dist/index.js"
      ]
    }
  }
}
